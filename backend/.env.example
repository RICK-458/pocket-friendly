# Server
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (the Vite dev server by default)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Razorpay TEST MODE keys — dashboard.razorpay.com → Settings → API Keys → Generate Test Key
# Test keys start with rzp_test_. Never commit the secret or use live keys here.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Auth — generate a long random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# PostgreSQL — either set DATABASE_URL…
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pocket_friendly

# …or the individual PG* variables (used when DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=pocket_friendly
