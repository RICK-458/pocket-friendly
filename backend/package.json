{
  "name": "pocket-friendly-backend",
  "version": "1.0.0",
  "description": "Express + PostgreSQL REST API for the Pocket-Friendly expense tracker",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:schema": "psql -U postgres -f database/schema.sql",
    "db:seed": "psql -U postgres -d pocket_friendly -f database/seed.sql"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.16.0",
    "razorpay": "^2.9.6"
  }
}
